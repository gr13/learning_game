{
    "mode": "closing_command",
    "command": "show_learned",
    "json_only": true,
    "description": "Return words confirmed as learned during the module session.",
    "schema": {
        "words": [
            "string"
        ]
    },
    "rules": {
        "return_only_words_from_session": true,
        "no_duplicates": true,
        "no_extra_keys": true,
        "no_missing_keys": true
    }
}